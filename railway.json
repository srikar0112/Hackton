{
    "$schema": "https://schema.railway.app/railwayapp-schema.json",
    "build": {
        "buildCommand": "npm run build"
    },
    "deploy": {
        "startCommand": "npm run start",
        "healthcheckPath": "/",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}